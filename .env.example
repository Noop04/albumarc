# Use 127.0.0.1 — Spotify rejects localhost for redirect URIs
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Spotify — create an app at https://developer.spotify.com/dashboard
# Redirect URI in dashboard: http://127.0.0.1:3000/api/auth/spotify/callback
# Dev Mode: max 5 users, Premium required, limited endpoints (see Spotify docs)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional override (defaults to NEXT_PUBLIC_APP_URL/api/auth/spotify/callback)
SPOTIFY_REDIRECT_URI=

# Required in production — encrypts OAuth session cookies (min 32 characters)
# Generate: openssl rand -base64 32
SESSION_SECRET=

# PostgreSQL — use Neon's POOLED connection string in production/serverless
# The pooler hostname contains "-pooler" (e.g. ep-xxx-pooler.us-east-1.aws.neon.tech)
# Direct connections exhaust Neon limits under Vercel's per-request serverless model
# Run migrations: npm run db:push
DATABASE_URL=

# Cron job auth — Vercel Cron sends Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -base64 32
CRON_SECRET=

# Upstash Redis — rate limiting + recommendation cache (required in production)
# Create at https://console.upstash.com — works natively with Vercel
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — error tracking in production (optional locally)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
